# Copy to .env and fill in. Used when you run: npm run server

# Required for "Send via app". Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional. Sender address. Default: Scheduler <onboarding@resend.dev>
# With onboarding@resend.dev you can send immediately; verify your domain in Resend to use your own.
# FROM_EMAIL=Scheduler <you@yourdomain.com>

# Optional. API server port (default 3001)
# PORT=3001

# Optional. Base URL of the web app for "choose your date" links in emails (default: http://localhost:5173)
# Set to your deployed app URL in production so recipients get the correct link.
# BASE_URL=https://your-scheduler-app.com
